-	defined (__DragonFly__) || defined (__APPLE__)
+	defined (__DragonFly__)
 #undef	d_ino
-#endif	/* __FreeBSD__ || __NetBSD__ || __OpenBSD__ || __DragonFly__
-	 || __APPLE__ */
+#endif	/* __FreeBSD__ || __NetBSD__ || __OpenBSD__ || __DragonFly__ */
